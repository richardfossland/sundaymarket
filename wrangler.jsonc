{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sundaymarket",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-05-05",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "routes": [{ "pattern": "marked.sundaysuite.app", "custom_domain": true }],
  "observability": {
    "enabled": true
  }
  // Runtime env (NEXT_PUBLIC_* are build-time inlined):
  //   SUPABASE_SERVICE_ROLE_KEY is a runtime Worker secret (only needed if
  //   server routes are added later — the game currently uses the anon key):
  //     npx wrangler secret put SUPABASE_SERVICE_ROLE_KEY
  //   ANTHROPIC_API_KEY is an OPTIONAL Worker secret powering the AI "town
  //   crier" narrator at app/api/director. Without it the game falls back to
  //   random world events and hides narration:
  //     npx wrangler secret put ANTHROPIC_API_KEY
}
